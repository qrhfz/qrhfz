<section class="bg-slate-50 py-8">
    <div class=" mx-auto px-8 lg:px-0 lg:w-2/3">
        <h2 class="text-3xl font-bold mb-4">Sertifikasi</h2>
        <% certs.forEach(cert => { %>
            <div class="pb-4">
                <h3 class="text-xl font-bold "><%- cert.title %> </h2>
                <div><%- cert.issuer %></div>
                <div><%- cert.start %> - <%- cert.end %></div>
                <div><a class="font-bold" href="<%- cert.url %>">
                    Lihat Sertifikat
                    <svg class="inline-block" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"><path d="m13 3 3.293 3.293-7 7 1.414 1.414 7-7L21 11V3z"></path><path d="M19 19H5V5h7l-2-2H5c-1.103 0-2 .897-2 2v14c0 1.103.897 2 2 2h14c1.103 0 2-.897 2-2v-5l-2-2v7z"></path></svg>
                </a></div>
            </div>
        <% }) %>
    </div>
</section>