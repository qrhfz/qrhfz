                break;
            case "unity":
                return '<svg class="inline-block" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path d="m10.4 17.8 1.21 2.07L19.77 22 22 14.08 20.72 12 22 10l-2.23-8-8.16 2.13L10.4 6.2H8L2 12l6 5.81zm9.92-5.8-1.73 6L15 12l3.59-6zM10.6 6.54 16.84 5l-3.59 6H6.08zM13.27 13l3.59 6-6.26-1.55L6.1 13z"></path></svg>'
                break;
            default:
                break;
        }
    }

%> 

<section class="bg-slate-200" id="portfolio">
        
    <div class="lg:w-2/3 mx-auto p-8 lg:px-0">
        <h2 class="text-3xl font-bold mb-8">Portofolio</h2>
        <% projects.forEach(project => { %>
            <div class="md:flex mb-12">
                <img src="<%= project.image %> " alt="" class="w-full md:w-64 mb-4 md:mb-0" width="150">
                <div class="flex flex-col md:pl-8 gap-2">
                    <div>
                        <h3 class="text-xl inline-block align-middle"><%= project.title %> </h3><%- icon(project.type) %> 
                    </div>
                    
                    <div class="flex gap-2">
                        <% if (project.demo) { %>
                            <a href="<%= project.demo  %>"  target="_blank" 
                                class="bg-slate-800 text-white 
                                py-1 px-3 rounded-full hover:bg-slate-700 
                                border-2">Demo</a>
                        <% } %>
                        <% if (project.store) { %>
                            <a href="<%= project.store  %>" target="_blank" 
                                class="bg-slate-800 text-white py-1 px-3 rounded-full 
                                hover:bg-slate-700 border-2">
                                <svg class="inline-block fill-white align-text-bottom" xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" ><path d="m12.954 11.616 2.957-2.957L6.36 3.291c-.633-.342-1.226-.39-1.746-.016l8.34 8.341zm3.461 3.462 3.074-1.729c.6-.336.929-.812.929-1.34 0-.527-.329-1.004-.928-1.34l-2.783-1.563-3.133 3.132 2.841 2.84zM4.1 4.002c-.064.197-.1.417-.1.658v14.705c0 .381.084.709.236.97l8.097-8.098L4.1 4.002zm8.854 8.855L4.902 20.91c.154.059.32.09.495.09.312 0 .637-.092.968-.276l9.255-5.197-2.666-2.67z"></path></svg>
                                Play Store
                            </a>
                        <% } %>
                        <a href="<%= project.src  %>" target="_blank" class="
                            bg-slate-50 text-slate-800 
                            py-1 px-3 rounded-full 
                            border-2 border-slate-500 
                            hover:bg-slate-100">
                            <svg class="inline-block fill-slate-800 align-text-bottom" xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24"><path d="m7.375 16.781 1.25-1.562L4.601 12l4.024-3.219-1.25-1.562-5 4a1 1 0 0 0 0 1.562l5 4zm9.25-9.562-1.25 1.562L19.399 12l-4.024 3.219 1.25 1.562 5-4a1 1 0 0 0 0-1.562l-5-4zm-1.649-4.003-4 18-1.953-.434 4-18z"></path></svg>
                            Source Code
                        </a>
                    </div>
                        
                    
                    <p>
                        <%= project.description %>
                    </p>
                </div>
            </div>
        <% }) %>

</section>